# Copy to .env — NEVER commit .env
# ── Exchange (leave blank for pure paper mode) ──────────────────
# binance is geo-blocked for US users; use kraken or coinbase
EXCHANGE=kraken
API_KEY=
API_SECRET=

# ── Mode: paper | testnet | live ─────────────────────────────────
MODE=paper

# ── Universe ─────────────────────────────────────────────────────
# Kraken uses USD pairs; Binance uses USDT
SYMBOLS=BTC/USD,ETH/USD,SOL/USD

# ── Risk controls ────────────────────────────────────────────────
CAPITAL=10000           # Starting capital (USD)
RISK_PER_TRADE=0.01     # 1% per trade
MAX_DAILY_LOSS=0.02     # 2% of capital halts trading for the day
MAX_EXPOSURE=0.20       # 20% total capital in open positions
MAX_POSITIONS=3         # Concurrent open positions
COOLDOWN_SECONDS=300    # Seconds between signals for same symbol

# ── Strategy parameters ──────────────────────────────────────────
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_LONG_THRESHOLD=55   # RSI must be > this for longs
RSI_SHORT_THRESHOLD=45  # RSI must be < this for shorts
ATR_PERIOD=14
ATR_SL_MULT=2.0         # Stop-loss = entry ± ATR * mult
ATR_TP_MULT=3.0         # Take-profit = entry ± ATR * mult

# ── Execution ────────────────────────────────────────────────────
TIMEFRAME=5m
POLL_INTERVAL=30        # Seconds between polls
OHLCV_LIMIT=200         # Candles to fetch per poll

# ── Infra ────────────────────────────────────────────────────────
DB_PATH=data/tradebot.db
LOG_PATH=data/trades.jsonl
HEALTH_PORT=8765
KILL_FILE=data/KILL
